@using GymMangment.BLL.ViewModels.BookingViewModels
@model IEnumerable<SessionScheduleViewModel>
@{
    ViewData["Title"] = "Sessions Schedule";
}

<div class="container">
    <header class="d-flex justify-content-between mt-5 mb-4 align-items-center">
        <div>
            <h2 class="text-primary-color mb-0">Sessions Schedule</h2>
            <p class="text-muted">View and book available training sessions</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a asp-controller="Bookings" asp-action="Index" class="btn btn-outline fw-medium rounded-pill px-4 py-3">
                <i class="bi bi-calendar-check me-2"></i>View All Bookings
            </a>
        }
        else if (User.IsInRole("Member"))
        {
            <a asp-controller="Bookings" asp-action="MyBookings" class="btn btn-outline fw-medium rounded-pill px-4 py-3">
                <i class="bi bi-calendar-check me-2"></i>My Bookings
            </a>
        }
    </header>

    @if (Model != null && Model.Any())
    {
        <div class="row g-4">
            @foreach (var session in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header text-white py-3 @(session.Status == "Ongoing" ? "bg-success" : session.Status == "Upcoming" ? "bg-primary-color" : "bg-secondary")">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-event me-2"></i>@session.CategoryName
                                </h5>
                                <span class="badge bg-light text-dark">@session.Status</span>
                            </div>
                        </div>
                        <div class="card-body">     
                            <p class="text-muted mb-3">@session.Description</p>
                            <div class="mb-2">
                                <i class="bi bi-person-circle text-primary-color me-2"></i>
                                <strong>Trainer:</strong> @session.TrainerName
                            </div>
                            <div class="mb-2">
                                <i class="bi bi-calendar3 text-primary-color me-2"></i>
                                <strong>Date:</strong> @session.DateDisplay
                            </div>
                            <div class="mb-2">
                                <i class="bi bi-clock text-primary-color me-2"></i>
                                <strong>Time:</strong> @session.TimeRangeDisplay
                            </div>
                            <div class="mb-2">
                                <i class="bi bi-people text-primary-color me-2"></i>
                                <strong>Available:</strong>
                                <span class="@(session.AvailableSlots == 0 ? "text-danger" : "text-success") fw-bold">
                                    @session.AvailableSlots/@session.Capacity slots
                                </span>
                            </div>
                        </div>
                        <div class="card-footer bg-white border-0 pb-3">
                            @if (session.CanBook)
                            {
                                <a asp-controller="SessionsSchedule" asp-action="Book" asp-route-id="@session.Id"
                                   class="btn btn-fill w-100">
                                    <i class="bi bi-calendar-plus me-1"></i>Book Session
                                </a>
                            }
                            else if (session.Status == "Completed")
                            {
                                <button class="btn btn-secondary w-100" disabled>
                                    <i class="bi bi-calendar-x me-1"></i>Session Completed
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-danger w-100" disabled>
                                    <i class="bi bi-x-circle me-1"></i>Fully Booked
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h4 class="mt-3 text-muted">No Sessions Available</h4>
            <p class="text-muted">Check back later for upcoming sessions</p>
           
        </div>
    }
</div>
